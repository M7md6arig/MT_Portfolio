generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  role         String @default("admin")
}

enum Category {
  poster
  video
  motion
  website
}

model Project {
  id           String   @id @default(cuid())
  title        String
  description  String
  category     Category
  thumbnailUrl String
  mediaUrl     String?
  liveUrl      String?
  tags         String[]
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([category, order])
}

model Service {
  id          String @id @default(cuid())
  title       String
  description String
  icon        String
  order       Int    @default(0)
}

model SocialLink {
  id       String @id @default(cuid())
  platform String
  url      String
  icon     String
  order    Int    @default(0)
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
